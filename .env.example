# Public (safe to expose to the browser) - used only if you ever need client-side reads
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (used inside app/api/* routes, NEVER imported by client components)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
